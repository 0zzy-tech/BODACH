# Ollama Cloud configuration
# Sign up at https://ollama.com to get an API key
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=your_ollama_api_key_here

# Model to use - must support tool/function calling
# Recommended: llama3.1, llama3.2, qwen2.5, mistral-nemo
OLLAMA_MODEL=llama3.1

# Session settings
SESSION_TTL=3600          # seconds before inactive sessions are evicted
SESSION_DB_PATH=/data/sessions.db

# Tool execution limits
MAX_TOOL_RUNTIME=300      # seconds before a tool is killed
